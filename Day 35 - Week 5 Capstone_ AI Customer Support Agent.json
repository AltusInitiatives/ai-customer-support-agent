    {
      "parameters": {
        "jsCode": "const output = $input.first().json.output;\n\n// Extract confidence score from the response\nconst confidenceMatch = output.match(/CONFIDENCE:\\s*(\\d+)/i);\nconst confidenceScore = confidenceMatch ? parseInt(confidenceMatch[1]) : 5;\n\n// Clean the response by removing the confidence line\nconst cleanResponse = output.replace(/\\nCONFIDENCE:\\s*\\d+/i, '').trim();\n\nreturn [{\n  json: {\n    response: cleanResponse,\n    confidence_score: confidenceScore,\n    escalate: confidenceScore < 7,\n    name: $('Webhook').first().json.body.name,\n    email: $('Webhook').first().json.body.email,\n    question: $('Webhook').first().json.body.question,\n    order_id: $('Webhook').first().json.body.order_id\n  }\n}];"
      },
